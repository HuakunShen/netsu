{
  "name": "netsu",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "e2e": "bash interop/e2e.sh",
    "e2e:quic": "bash interop/transports/e2e-quic.sh",
    "signal:dev": "bun run --cwd apps/rendez-key dev",
    "signal:test": "bun run --cwd apps/rendez-key test",
    "signal:typecheck": "bun run --cwd apps/rendez-key typecheck",
    "signal:deploy:dry": "bun run --cwd apps/rendez-key deploy:dry",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.3.0",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
