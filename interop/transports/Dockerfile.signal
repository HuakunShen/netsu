FROM oven/bun:1.3.14 AS bun-runtime

FROM node:22.18.0-bookworm-slim

COPY --from=bun-runtime /usr/local/bin/bun /usr/local/bin/bun
WORKDIR /repo
COPY . ./
RUN bun install --frozen-lockfile

WORKDIR /repo/apps/rendez-key
CMD ["node", "/repo/node_modules/wrangler/bin/wrangler.js", "dev", "--local", "--ip", "0.0.0.0", "--port", "8787", "--persist-to", "/tmp/netsu-signal", "--var", "PUBLIC_SIGNAL_CREATE:true", "--log-level", "warn", "--show-interactive-dev-session", "false"]
