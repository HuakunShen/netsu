    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.31",
    "hono-openapi": "^1.3.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0",
    "zod": "^4.1.0"
